# Backend environment variables (prod profile). Copy to .env for local prod-like runs.
SPRING_PROFILES_ACTIVE=prod
DATABASE_URL=jdbc:postgresql://localhost:5432/expensetracker
DB_USER=postgres
DB_PASSWORD=changeme
FRONTEND_ORIGIN=http://localhost:5173
# Random string, minimum 32 characters (e.g. `openssl rand -base64 48`)
JWT_SECRET=replace-with-a-random-string-of-at-least-32-chars
JWT_EXPIRATION_MINUTES=1440
